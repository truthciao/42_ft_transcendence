#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/boxlin/code42/transcendence/node_modules/.pnpm/oxlint@1.73.0/node_modules/oxlint/node_modules:/home/boxlin/code42/transcendence/node_modules/.pnpm/oxlint@1.73.0/node_modules:/home/boxlin/code42/transcendence/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/boxlin/code42/transcendence/node_modules/.pnpm/oxlint@1.73.0/node_modules/oxlint/node_modules:/home/boxlin/code42/transcendence/node_modules/.pnpm/oxlint@1.73.0/node_modules:/home/boxlin/code42/transcendence/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../bin/oxlint" "$@"
else
  exec node  "$basedir/../../bin/oxlint" "$@"
fi
